{
  "name": "kaicrit",
  "displayName": "kaicrit — CriticMarkup",
  "description": "CriticMarkup for VS Code: edit, compare two files into CriticMarkup, and preview changes in the built-in Markdown preview.",
  "version": "0.5.0",
  "publisher": "0x2e6b6169",
  "author": {
    "name": "0x2e6b6169",
    "url": "https://blog.0x2e6b6169.de"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kaijen/kaicrit.git"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Formatters"
  ],
  "keywords": [
    "criticmarkup",
    "markdown",
    "track changes",
    "diff",
    "compare",
    "preview",
    "review"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kaicrit.insertDeletion",
        "title": "Insert Deletion",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.insertAddition",
        "title": "Insert Addition",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.insertSubstitution",
        "title": "Insert Substitution",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.insertHighlight",
        "title": "Insert Highlight",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.insertComment",
        "title": "Insert Comment",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.nextChange",
        "title": "Next Change",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.prevChange",
        "title": "Previous Change",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.firstChange",
        "title": "First Change",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.lastChange",
        "title": "Last Change",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.acceptChange",
        "title": "Accept Change at Cursor",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.rejectChange",
        "title": "Reject Change at Cursor",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.acceptAll",
        "title": "Accept All Changes",
        "category": "CriticMarkup",
        "icon": "$(check-all)"
      },
      {
        "command": "kaicrit.rejectAll",
        "title": "Reject All Changes",
        "category": "CriticMarkup",
        "icon": "$(close-all)"
      },
      {
        "command": "kaicrit.acceptChangeAt",
        "title": "Accept Change (at position)",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.rejectChangeAt",
        "title": "Reject Change (at position)",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.revealChangeAt",
        "title": "Reveal Change (at position)",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.acceptChangeNode",
        "title": "Accept Change",
        "category": "CriticMarkup",
        "icon": "$(check)"
      },
      {
        "command": "kaicrit.rejectChangeNode",
        "title": "Reject Change",
        "category": "CriticMarkup",
        "icon": "$(x)"
      },
      {
        "command": "kaicrit.toggleTrackChanges",
        "title": "Toggle Track Changes",
        "category": "CriticMarkup",
        "icon": "$(edit)"
      },
      {
        "command": "kaicrit.toggleFileEnabled",
        "title": "Toggle CriticMarkup for This File",
        "category": "CriticMarkup",
        "icon": "$(eye)"
      },
      {
        "command": "kaicrit.compareFiles",
        "title": "Compare Two Files → CriticMarkup",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.compareActiveFileWith",
        "title": "Compare Active File With… → CriticMarkup",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.compareWithGitHead",
        "title": "Compare Active File with Git HEAD → CriticMarkup",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.selectForCompare",
        "title": "Select for CriticMarkup Compare",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.compareWithSelected",
        "title": "Compare with Selected → CriticMarkup",
        "category": "CriticMarkup"
      },
      {
        "command": "kaicrit.compareSelected",
        "title": "Compare Selected Files → CriticMarkup",
        "category": "CriticMarkup"
      }
    ],
    "colors": [
      {
        "id": "kaicrit.deletionForeground",
        "description": "Foreground color for deleted text.",
        "defaults": {
          "dark": "editorError.foreground",
          "light": "editorError.foreground",
          "highContrast": "editorError.foreground",
          "highContrastLight": "editorError.foreground"
        }
      },
      {
        "id": "kaicrit.additionForeground",
        "description": "Foreground color for added text.",
        "defaults": {
          "dark": "gitDecoration.addedResourceForeground",
          "light": "gitDecoration.addedResourceForeground",
          "highContrast": "gitDecoration.addedResourceForeground",
          "highContrastLight": "gitDecoration.addedResourceForeground"
        }
      },
      {
        "id": "kaicrit.substitutionOldForeground",
        "description": "Foreground color for the removed part of a substitution.",
        "defaults": {
          "dark": "editorError.foreground",
          "light": "editorError.foreground",
          "highContrast": "editorError.foreground",
          "highContrastLight": "editorError.foreground"
        }
      },
      {
        "id": "kaicrit.substitutionNewForeground",
        "description": "Foreground color for the inserted part of a substitution.",
        "defaults": {
          "dark": "gitDecoration.addedResourceForeground",
          "light": "gitDecoration.addedResourceForeground",
          "highContrast": "gitDecoration.addedResourceForeground",
          "highContrastLight": "gitDecoration.addedResourceForeground"
        }
      },
      {
        "id": "kaicrit.highlightBackground",
        "description": "Background color for highlighted text.",
        "defaults": {
          "dark": "#ffff00",
          "light": "#ffff00",
          "highContrast": "#ffff00",
          "highContrastLight": "#ffff00"
        }
      },
      {
        "id": "kaicrit.highlightForeground",
        "description": "Foreground color for highlighted text.",
        "defaults": {
          "dark": "#333333",
          "light": "#333333",
          "highContrast": "#333333",
          "highContrastLight": "#333333"
        }
      },
      {
        "id": "kaicrit.commentBackground",
        "description": "Background color for comment text.",
        "defaults": {
          "dark": "#e0e0e0",
          "light": "#e0e0e0",
          "highContrast": "#e0e0e0",
          "highContrastLight": "#e0e0e0"
        }
      },
      {
        "id": "kaicrit.commentForeground",
        "description": "Foreground color for comment text.",
        "defaults": {
          "dark": "#555555",
          "light": "#555555",
          "highContrast": "#555555",
          "highContrastLight": "#555555"
        }
      }
    ],
    "keybindings": [
      {
        "command": "kaicrit.nextChange",
        "key": "alt+k alt+down",
        "when": "editorTextFocus"
      },
      {
        "command": "kaicrit.prevChange",
        "key": "alt+k alt+up",
        "when": "editorTextFocus"
      },
      {
        "command": "kaicrit.firstChange",
        "key": "alt+k alt+home",
        "when": "editorTextFocus"
      },
      {
        "command": "kaicrit.lastChange",
        "key": "alt+k alt+end",
        "when": "editorTextFocus"
      },
      {
        "command": "kaicrit.acceptChange",
        "key": "alt+a",
        "when": "editorTextFocus && kaicrit.hasChanges"
      },
      {
        "command": "kaicrit.rejectChange",
        "key": "alt+r",
        "when": "editorTextFocus && kaicrit.hasChanges"
      },
      {
        "command": "kaicrit.acceptAll",
        "key": "alt+k enter",
        "when": "editorTextFocus"
      },
      {
        "command": "kaicrit.rejectAll",
        "key": "alt+k backspace",
        "when": "editorTextFocus"
      },
      {
        "command": "kaicrit.insertDeletion",
        "key": "alt+k alt+d",
        "when": "editorTextFocus"
      },
      {
        "command": "kaicrit.insertAddition",
        "key": "alt+k alt+a",
        "when": "editorTextFocus"
      },
      {
        "command": "kaicrit.insertSubstitution",
        "key": "alt+k alt+s",
        "when": "editorTextFocus"
      },
      {
        "command": "kaicrit.insertHighlight",
        "key": "alt+k alt+h",
        "when": "editorTextFocus"
      },
      {
        "command": "kaicrit.insertComment",
        "key": "alt+k alt+c",
        "when": "editorTextFocus"
      },
      {
        "command": "kaicrit.toggleTrackChanges",
        "key": "alt+k alt+t",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "kaicrit.acceptChangeAt",
          "when": "false"
        },
        {
          "command": "kaicrit.rejectChangeAt",
          "when": "false"
        },
        {
          "command": "kaicrit.revealChangeAt",
          "when": "false"
        },
        {
          "command": "kaicrit.acceptChangeNode",
          "when": "false"
        },
        {
          "command": "kaicrit.rejectChangeNode",
          "when": "false"
        },
        {
          "command": "kaicrit.selectForCompare",
          "when": "false"
        },
        {
          "command": "kaicrit.compareWithSelected",
          "when": "false"
        },
        {
          "command": "kaicrit.compareSelected",
          "when": "false"
        }
      ],
      "editor/context": [
        {
          "command": "kaicrit.compareWithGitHead",
          "when": "resourceScheme == file",
          "group": "3_compare@1"
        }
      ],
      "editor/title": [
        {
          "command": "kaicrit.toggleTrackChanges",
          "when": "editorIsOpen",
          "group": "navigation@9"
        }
      ],
      "explorer/context": [
        {
          "command": "kaicrit.selectForCompare",
          "when": "!explorerResourceIsFolder",
          "group": "3_compare@1"
        },
        {
          "command": "kaicrit.compareWithSelected",
          "when": "!explorerResourceIsFolder",
          "group": "3_compare@2"
        },
        {
          "command": "kaicrit.compareSelected",
          "when": "!explorerResourceIsFolder && listDoubleSelection",
          "group": "3_compare@3"
        }
      ],
      "view/title": [
        {
          "command": "kaicrit.acceptAll",
          "when": "view == kaicrit.changes",
          "group": "navigation@1"
        },
        {
          "command": "kaicrit.rejectAll",
          "when": "view == kaicrit.changes",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "kaicrit.acceptChangeNode",
          "when": "view == kaicrit.changes && viewItem == kaicrit.change",
          "group": "inline@1"
        },
        {
          "command": "kaicrit.rejectChangeNode",
          "when": "view == kaicrit.changes && viewItem == kaicrit.change",
          "group": "inline@2"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kaicrit",
          "title": "CriticMarkup",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "kaicrit": [
        {
          "id": "kaicrit.changes",
          "name": "Changes",
          "contextualTitle": "CriticMarkup Changes"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "kaicrit.changes",
        "contents": "No CriticMarkup changes in the active editor.\nOpen a document with CriticMarkup, or insert a change to see it listed here grouped by type."
      }
    ],
    "configuration": {
      "title": "kaicrit",
      "properties": {
        "kaicrit.enabledLanguages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["markdown", "plaintext"],
          "markdownDescription": "Language ids for which kaicrit's editor features (decorations, inline CodeLens, status bar, Changes view, accept/reject) are active. Matched against a document's language id; use `\"*\"` to enable every language. Override per file with the `$(eye) CriticMarkup` toggle in the status bar (session-only)."
        },
        "kaicrit.edit.codeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show inline \"Accept | Reject\" CodeLens actions above each CriticMarkup change in the editor."
        },
        "kaicrit.edit.commentMetadata": {
          "type": "boolean",
          "default": true,
          "description": "Recognize the optional author/date convention in comments ({>>@author YYYY-MM-DD: text<<}): show the metadata in editor hovers and the preview, and pre-fill it when inserting a comment. When off, comments are treated as plain text."
        },
        "kaicrit.edit.commentAuthor": {
          "type": "string",
          "default": "",
          "description": "Author name pre-filled when inserting a comment with metadata. When empty, falls back to the repository's git config user.name."
        },
        "kaicrit.edit.trackChanges": {
          "type": "boolean",
          "default": false,
          "description": "Start newly opened documents with Track Changes recording on: edits are captured as CriticMarkup (deletions → {--…--}, insertions → {++…++}, replacements → {~~…~>…~~}) instead of changing the text directly. Toggle per document with the \"Toggle Track Changes\" command (Alt+K Alt+T)."
        },
        "kaicrit.edit.decorationDebounce": {
          "type": "integer",
          "default": 150,
          "minimum": 0,
          "description": "Delay in milliseconds between a document edit and the re-parse that refreshes CriticMarkup decorations, the status bar, and the Changes view. Higher values coalesce bursts of typing into a single parse (helpful in large documents that already contain markers); lower values update more eagerly. Accept/Reject still refresh immediately regardless of this value. Set to 0 to parse on the next tick."
        },
        "kaicrit.compare.granularity": {
          "type": "string",
          "enum": ["character", "word", "line"],
          "enumDescriptions": [
            "Diff character by character (most precise, noisiest output).",
            "Diff word by word while preserving whitespace (recommended for prose).",
            "Diff line by line (best for code and structured text)."
          ],
          "default": "word",
          "description": "Granularity used when diffing two files into CriticMarkup."
        },
        "kaicrit.compare.combineSubstitutions": {
          "type": "boolean",
          "default": true,
          "description": "Merge an adjacent deletion and addition into a single CriticMarkup substitution {~~old~>new~~} instead of emitting separate {--old--}{++new++} markers."
        },
        "kaicrit.compare.ignoreWhitespace": {
          "type": "boolean",
          "default": false,
          "description": "Ignore whitespace-only differences when diffing: tokens that differ only in whitespace are not marked as changes (similar to `git diff -w`). The original text is still reproduced verbatim when rejecting every marker."
        },
        "kaicrit.compare.outputLanguage": {
          "type": "string",
          "enum": ["auto", "plaintext", "markdown"],
          "enumDescriptions": [
            "Use the language of the second (modified) file.",
            "Always open the result as plain text.",
            "Always open the result as Markdown."
          ],
          "default": "auto",
          "description": "Language mode applied to the generated CriticMarkup document."
        },
        "kaicrit.compare.maxDiffTokens": {
          "type": "integer",
          "default": 4000000,
          "minimum": 0,
          "description": "Safety guard for the diff engine: the maximum allowed token product (tokens in file 1 × tokens in file 2) before a compare is considered too large. Myers' diff degrades towards O((n+m)²) memory/time on two very different files, so an unbounded run on huge inputs (especially at `character` granularity) can freeze VS Code. When the limit is exceeded the compare automatically retries at `line` granularity; if that is still too large it is aborted with a warning. Set to 0 to disable the guard (not recommended)."
        }
      }
    },
    "markdown.markdownItPlugins": true,
    "markdown.previewStyles": [
      "./media/critic.css"
    ]
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "tsc -p ./ && node --test out/compare/*.test.js out/core/*.test.js out/edit/*.test.js out/preview/*.test.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.3.0"
  }
}
